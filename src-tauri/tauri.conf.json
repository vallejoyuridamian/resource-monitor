{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resource Monitor",
  "version": "0.1.0",
  "identifier": "com.bitsandbolts.resourcemonitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm run vite",
    "beforeBuildCommand": "pnpm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Resource Monitor",
        "width": 960,
        "height": 620,
        "minWidth": 640,
        "minHeight": 440,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
